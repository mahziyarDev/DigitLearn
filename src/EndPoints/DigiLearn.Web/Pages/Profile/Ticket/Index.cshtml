@page
@using TicketModule.Data.Entities
@using Common.Application.DateUtil
@model DigiLearn.Web.Pages.Profile.Ticket.IndexModel
@{
    Layout = "_Layout"; 
    TempData["Title"] = "تیکت ها";
    var counter = 1;
}
@section Styles {
    <link href="~/assets/profilesidebar/profilesidebar.min.css" rel="stylesheet" />
}
<section class="blog-area ptb-100">
    <div class="container">
        <div class="row">
            <partial name="_ProfileSideBar" />
            <div class="col-lg-8 col-md-12">

                <nav aria-label="breadcrumb" class="mb-4">
                    <ol class="breadcrumb bg-white p-3 rounded-3 shadow-sm mb-0">
                        <li class="breadcrumb-item">
                            <a asp-page="/Index" class="text-decoration-none">
                                <i class='bx bx-home'></i> خانه
                            </a>
                        </li>
                        <li class="breadcrumb-item">
                            <a asp-page="/Profile/Index" class="text-decoration-none">
                                <i class='bx bx-user'></i> پروفایل
                            </a>
                        </li>
                        <li class="breadcrumb-item active" aria-current="page">
                            <i class="bx bx-paper-plane icon-arrow after"></i> تیکت ها
                        </li>
                    </ol>
                </nav>


                <div class="row">
                    <div class="d-flex align-items-center">
                        
                            <h3>تیکت ها</h3>
                      
                    </div>
                    <div class="recent-orders-table table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>عنوان</th>
                                    <th>وضعیت</th>
                                    <th>تاریخ ثبت</th>
                                    <th>عملیات</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.FilterResult.Data)
                                {
                                    <tr>
                                        <td>#@counter</td>
                                        <td>@item.Title</td>
                                        <td>
                                            @switch (item.Status)
                                            {
                                                case TicketStatus.Pending:
                                                    <span class="badge badge-info">درحال برسی</span>
                                                    break;
                                                case TicketStatus.Answered:
                                                    <span class="badge badge-success">پاسخ داده شده</span>
                                                    break;
                                                case TicketStatus.Closed:
                                                    <span class="badge badge-danger">بسته شده</span>
                                                    break;
                                            }
                                        </td>
                                        <td>
                                            @item.CreationDate.ToPersianDate()
                                        </td>

                                        <td><a asp-page="/Profile/Ticket/ShowTicket" asp-route-ticketId="@item.Id" class=" btn view-button">مشاهده</a></td>
                                    </tr>
                                    counter += 1;
                                }
                                @if (Model.FilterResult.EntityCount == 0)
                                {
                                    <tr>
                                        <td colspan="5" class="text-center">موردی برای نمایش وجود ندارد</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <partial name="Shared/_Pagination" model="Model.FilterResult"/>
                </div>
            </div>
        </div>
    </div>
</section>
@section Scripts {
    <script src="~/assets/profilesidebar/profilesidebar.js"></script>
}
