@page
@model DigiLearn.Web.Pages.Auth.LoginModel
@{
    Layout = "Shared/_AuthLayout";
    ViewData["title"] = "ورود";
}

<section class="register-area">
    <div class="row m-0">
        <div class="col-lg-6 col-md-12 p-0">
            <div class="register-image">
                <img src="/assets/img/register-bg.jpg" alt="image">
            </div>
        </div>

        <div class="col-lg-6 col-md-12 p-0">
            <div class="register-content">
                <div class="d-table">
                    <div class="d-table-cell">
                        <div class="register-form">
                            <div class="logo">
                                <a href="index.html"><img src="/assets/img/black-logo.png" alt="image"></a>
                            </div>

                            <h3>اکنون حساب خود را بسازید</h3>
                            <p>ثبت نام کرده اید؟ <a asp-action="/Auth/login">ثبت نام</a></p>

                            <form method="post">
                                <div class="form-group">
                                    <input type="text" asp-for="PhoneNumber" placeholder="شماره همراه" class="form-control">
                                    <span asp-validation-for="PhoneNumber"></span>
                                </div>

                                <div class="form-group">
                                    <input type="password" asp-for="Password" placeholder="رمز عبور" class="form-control">
                                    <span asp-validation-for="Password"></span>
                                </div>

                                <div class="mb-3 form-check">
                                    <input type="checkbox" asp-for="IsRememberMe" class="form-check-input" id="rememberMe">
                                    <label class="form-check-label mx-4" for="rememberMe">مرا به خاطر بسپار</label>
                                </div>
                                

                                <button type="submit">ثبت نام</button>

                                @* <div class="connect-with-social">
                                    <span>یا</span>
                                    <button type="submit" class="facebook"><i class="bx bxl-facebook"></i> اتصال با فیسبوک</button>
                                    <button type="submit" class="twitter"><i class="bx bxl-twitter"></i> اتصال با توئیتر</button>
                                </div> *@
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>